# Core local broker settings
AI_PROXY_HOST=127.0.0.1
AI_PROXY_PORT=3015
OLLAMA_BASE=http://127.0.0.1:11434
TTS_BASE=http://127.0.0.1:8880
OPENAI_BASE=https://api.openai.com
OPENAI_API_KEY=

# Optional runtime auth
TERMINAL_ADMIN_PASSWORD=

# Optional proxy tuning
AI_PROXY_ALLOWED_ORIGINS=https://cornerstone.aparcedo.org,http://127.0.0.1:3000,http://localhost:3000
AI_PROXY_ALLOW_REMOTE=
OLLAMA_TIMEOUT=120
TTS_TIMEOUT=60
OPENAI_TIMEOUT=45
MAX_OLLAMA_CONCURRENCY=2
MAX_TTS_CONCURRENCY=5
MAX_OPENAI_CONCURRENCY=6
FORCED_OLLAMA_MODEL=FieldMouse-AI/qwen3.5:0.8b-Q4_K_M
ALLOWED_OLLAMA_MODELS=FieldMouse-AI/qwen3.5:0.8b-Q4_K_M
